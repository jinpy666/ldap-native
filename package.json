{
  "name": "ldap-native",
  "version": "0.1.0",
  "description": "ldapts-compatible Node.js client backed by OpenLDAP libldap with Kerberos/GSSAPI support",
  "license": "MIT",
  "type": "commonjs",
  "main": "./index.cjs",
  "types": "./types/index.d.ts",
  "module": "./index.mjs",
  "exports": {
    ".": {
      "require": "./index.cjs",
      "import": "./index.mjs",
      "types": "./types/index.d.ts"
    },
    "./ber": {
      "require": "./ber.cjs",
      "import": "./ber.mjs",
      "types": "./types/ber/index.d.ts"
    },
    "./controls": {
      "require": "./controls.cjs",
      "import": "./controls.mjs",
      "types": "./types/controls/index.d.ts"
    },
    "./dn": {
      "require": "./dn.cjs",
      "import": "./dn.mjs",
      "types": "./types/dn/index.d.ts"
    },
    "./errors": {
      "require": "./errors.cjs",
      "import": "./errors.mjs",
      "types": "./types/errors/index.d.ts"
    },
    "./filters": {
      "require": "./filters.cjs",
      "import": "./filters.mjs",
      "types": "./types/filters/index.d.ts"
    }
  },
  "files": [
    "*.cjs",
    "*.mjs",
    "src/*.cjs",
    "types",
    "prebuilds",
    "binding.gyp",
    "native",
    "index.d.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:compat && node scripts/build-native.cjs && node scripts/create-prebuild.cjs",
    "build:native": "node scripts/build-native.cjs",
    "rebuild": "npm run build",
    "test": "npm run build:compat && npm run test:unit && npm run test:imports && npm run test:upstream",
    "test:full": "npm run build && npm run test:unit && npm run test:imports && npm run test:upstream && npm run smoke && npm run test:integration:docker",
    "test:unit": "node scripts/run-unit-tests.cjs",
    "test:imports": "node scripts/run-import-tests.cjs",
    "test:integration": "node scripts/run-integration-tests.cjs",
    "test:integration:docker": "node scripts/run-docker-tests.cjs",
    "smoke": "node examples/smoke-native.cjs",
    "build:compat": "tsc -p tsconfig.json",
    "test:upstream": "node scripts/run-upstream-direct.cjs",
    "ci": "npm run build:compat && npm run test:unit && npm run test:imports && npm run test:upstream",
    "prepack": "npm run build:compat",
    "test:integration:mockable": "node scripts/run-integration-tests.cjs",
    "release:verify": "npm run build:compat && npm run test:unit && npm run test:imports && npm run test:upstream && npm pack --dry-run",
    "test:docker": "npm run build && npm run test:integration:docker",
    "docker:up": "bash docker/openldap/tls/generate-certs.sh && docker compose up -d --wait",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs openldap"
  },
  "keywords": [
    "ldap",
    "openldap",
    "kerberos",
    "gssapi",
    "napi",
    "ldapts"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinpy666/ldap-native.git"
  },
  "homepage": "https://github.com/jinpy666/ldap-native#readme",
  "bugs": {
    "url": "https://github.com/jinpy666/ldap-native/issues"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "node-gyp": "^11.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "node-addon-api": "^8.7.0"
  }
}
