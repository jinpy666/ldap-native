{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowJs": false,
    "outDir": "compat-cjs",
    "rootDir": ".",
    "skipLibCheck": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "upstream-src/**/*.ts",
    "compat-cjs/**/*.d.ts"
  ]
}
